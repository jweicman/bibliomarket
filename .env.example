# ─── OCA (Correo OCA) ─────────────────────────────────────────────────────────
OCA_USERNAME="tu-usuario-oca"
OCA_PASSWORD="tu-contraseña-oca"
OCA_CUENTA_CORRIENTE="tu-numero-cuenta"
