# ─── DATABASE ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/bibliomarket?schema=public"

# ─── NEXTAUTH ─────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
